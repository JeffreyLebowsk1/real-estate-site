# Caddyfile — homes.mdilworth.com
#
# Cloudflare's orange-cloud proxy (via the cccc-notes tunnel) terminates TLS.
# Caddy therefore only needs plain HTTP; auto_https is disabled.
#
# Listens on :8081 so Caddy runs without root / CAP_NET_BIND_SERVICE.
# The cloudflared tunnel config points to http://localhost:8081.

{
    auto_https off
}

:8081 {
    # Proxy API, admin, and webhook calls to the Flask/Gunicorn backend
    reverse_proxy /api/* 127.0.0.1:5001
    reverse_proxy /admin* 127.0.0.1:5001
    reverse_proxy /webhook/* 127.0.0.1:5001

    # Serve static front-end files
    root * /home/madmatter/real-estate-site
    file_server

    encode gzip

    log {
        output stderr
    }
}
