# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where lead notifications are sent
NOTIFY_EMAIL=matt@mdilworth.com

# PostgreSQL connection string
DATABASE_URL=postgresql://mdilworth:changeme@localhost/mdilworth

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret

# Admin panel password hash — generate with:
#   python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Spam score threshold (0-10). Submissions >= this score are silently flagged.
SPAM_THRESHOLD=5

# Server port (gunicorn will use this)
PORT=5000
