# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where lead notifications are sent
NOTIFY_EMAIL=matt@mdilworth.com

# Optional: override the From address and display name used on outgoing
# notification emails.  This is important when NOTIFY_EMAIL is routed back
# to the same Gmail account used as SMTP_USER (e.g. via Cloudflare Email
# Routing) — Gmail deduplicates mail it considers self-sent and won't show
# it in your inbox.  Setting FROM_EMAIL to a verified Gmail alias
# (e.g. noreply@mdilworth.com) makes the From address differ from the
# destination address and prevents deduplication.
# If omitted, FROM_EMAIL defaults to SMTP_USER and FROM_NAME is left blank.
FROM_EMAIL=noreply@mdilworth.com
FROM_NAME=mdilworth.com

# PostgreSQL connection string
DATABASE_URL=postgresql://mdilworth:changeme@localhost/mdilworth

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret

# HMAC secret used to authenticate GitHub Actions deploy webhooks.
# Must match JETSON_WEBHOOK_SECRET in GitHub repo secrets.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=change-this-to-a-random-secret

# Admin panel password hash — generate with:
#   python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Spam score threshold (0-10). Submissions >= this score are silently flagged.
SPAM_THRESHOLD=5

# Server port (gunicorn will use this)
PORT=5000
